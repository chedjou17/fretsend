# ================================================
# FRETSEND BACKEND — Configuration
# Copier ce fichier en .env et remplir les valeurs
# ================================================

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase (Settings → API dans votre projet Supabase)
SUPABASE_URL=https://VOTRE_ID.supabase.co
SUPABASE_ANON_KEY=eyJ...votre_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...votre_service_role_key

# JWT — Mettez des secrets longs et aléatoires en production
JWT_SECRET=fretsend_jwt_secret_changez_en_production_2025
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=fretsend_refresh_secret_changez_en_production_2025
JWT_REFRESH_EXPIRES_IN=7d

# Freesend (https://freesend.metafog.io/docs/api/send-email)
FREESEND_API_KEY=votre_clé_freesend
FREESEND_FROM=noreply@fretsend.com
